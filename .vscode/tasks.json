{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "C/C++: mkdir build dir",
            "command": "pwsh",
            "type": "shell",
            "args": [
                "-NoProfile",
                "-Command",
                "& { New-Item -ItemType Directory -Force -Path \"${workspaceFolder}/build\" }"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "none"
        },
        {
            "label": "C/C++: g++.exe build all",
            "type": "cppbuild",
            "command": "g++.exe",
            "args": [
                "-std=c++17",
                "-Wall",
                "-Wextra",
                "-g",
                "${workspaceFolder}\\main.cpp",
                "${workspaceFolder}\\resistor.cpp",
                "${workspaceFolder}\\capacitor.cpp",
                "${workspaceFolder}\\inductor.cpp",
                "${workspaceFolder}\\seriescircuit.cpp",
                "${workspaceFolder}\\parallelcircuit.cpp",
                "-o",
                "${workspaceFolder}\\build\\circuit.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Builds circuit.exe into build/ directory from all source files.",
            "dependsOn": ["C/C++: mkdir build dir"]
        }
    ]
}